# ==================================================
# SQL Server Bağlantı Bilgileri
# ==================================================
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun
# ASLA .env dosyasını Git'e commit etmeyin!

# SQL Server (Tailscale VPN üzerinden)
SQL_SERVER=your_server_ip
SQL_PORT=14330
SQL_DATABASE=your_database_name
SQL_USERNAME=your_username
SQL_PASSWORD=your_password_here

# ==================================================
# LLM / AI Ayarları
# ==================================================
# Aktif provider: gemini | anthropic | openai
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
AI_DEFAULT_MODEL=gemini-2.0-flash

# OpenRouter için (ücretsiz yedek modeller)
# OPENROUTER_API_KEY=your-openrouter-key
# OPENROUTER_MODEL=openrouter/free

# Anthropic (isteğe bağlı)
# ANTHROPIC_API_KEY=sk-ant-...

# Rate limit
AI_RATE_LIMIT_PER_MINUTE=10
AI_RATE_LIMIT_PER_DAY=200

# ==================================================
# Opsiyonel Ayarlar
# ==================================================

# Chunk boyutu (varsayılan: 10000)
SYNC_CHUNK_SIZE=10000
CACHE_DIR=data/cache
CACHE_FILENAME=sales_cache.db
SYNC_FULL_REFRESH=false
SYNC_LOG_LEVEL=INFO
SQL_CONNECTION_TIMEOUT=60
SQL_QUERY_TIMEOUT=300
