# Django Core Settings
SECRET_KEY=django-insecure-your-secret-key-CHANGE-THIS-IN-PRODUCTION
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Database Configuration
# For production, use PostgreSQL instead of SQLite
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# PostgreSQL Example (recommended for production):
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=showplus_db
# DB_USER=showplus_user
# DB_PASSWORD=your_secure_password
# DB_HOST=localhost
# DB_PORT=5432

# CORS Settings
# Add all allowed frontend origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# JWT Authentication
# Generate a secure random key: python -c "import secrets; print(secrets.token_urlsafe(50))"
JWT_SECRET=your-jwt-secret-key-CHANGE-THIS
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=168

# Redis Cache (optional - for production)
# REDIS_URL=redis://localhost:6379/0

# Email Configuration (optional)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# -------------------------------------------------------
# LLM / AI Ayarları
# -------------------------------------------------------
# Aktif provider: gemini | anthropic | openai
LLM_PROVIDER=gemini

# Gemini (varsayılan)
GEMINI_API_KEY=your-gemini-api-key-here
# Model önerileri: gemini-2.5-flash | gemini-2.0-flash
# AI_DEFAULT_MODEL=gemini-2.5-flash (ücretli)
AI_DEFAULT_MODEL=gemini-2.0-flash

# OpenRouter (ücretsiz yedek)
# OPENROUTER_API_KEY=your-openrouter-key-here
# OPENROUTER_MODEL=openrouter/free

# Anthropic (Claude) — isteğe bağlı, LLM_PROVIDER=anthropic yapıldığında aktif
# ANTHROPIC_API_KEY=sk-ant-...
# AI_DEFAULT_MODEL=claude-haiku-4-5-20251001

# Rate limit
AI_RATE_LIMIT_PER_MINUTE=10
AI_RATE_LIMIT_PER_DAY=200

# -------------------------------------------------------
# Security Settings (for production)
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
